#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running PHP lint checks before push..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Run PHP linter
composer run lint

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ PUSH REJECTED: Lint errors found!"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "Please fix the lint errors before pushing:"
  echo "  • Run: composer run lint:fix (auto-fix)"
  echo "  • Or manually fix the errors"
  echo "  • Then try pushing again"
  echo ""
  exit 1
fi

echo "✅ All lint checks passed!"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
