{
  "name": "mbn-theme",
  "private": true,
  "scripts": {
    "build": "npm-run-all build:*",
    "build:css": "tailwindcss -i ./resources/css/app.css -o ./assets/build/tailwind.css --minify",
    "build:blocks": "wp-scripts build",
    "start": "npm-run-all --parallel watch:*",
    "watch:css": "tailwindcss -i ./resources/css/app.css -o ./assets/build/tailwind.css --watch",
    "watch:blocks": "wp-scripts start",
    "watch:browser": "browser-sync start --config bs-config.js",
    "dev": "npm-run-all --parallel watch:*",
    "prepare": "husky",
    "lint:php": "composer run lint",
    "lint:php:fix": "composer run lint:fix"
  },
  "dependencies": {
    "@wordpress/block-editor": "^12.15.0",
    "@wordpress/blocks": "^12.24.0",
    "@wordpress/components": "^25.13.0",
    "@wordpress/element": "^5.24.0",
    "@wordpress/i18n": "^4.47.0",
    "@wordpress/icons": "^9.38.0"
  },
  "devDependencies": {
    "@wordpress/scripts": "^27.9.0",
    "autoprefixer": "^10.4.20",
    "browser-sync": "^3.0.2",
    "copy-webpack-plugin": "^14.0.0",
    "glob": "^13.0.6",
    "husky": "^9.0.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.17"
  }
}
